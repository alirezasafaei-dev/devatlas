# DevAtlas local environment template
# Copy to `.env` for local development.

# Shared
NODE_ENV=development

# API
PORT=3001
APP_BASE_URL=http://localhost:3001
DATABASE_URL=postgresql://devatlas:devatlas@localhost:5432/devatlas?schema=public
TEST_DATABASE_URL=postgresql://devatlas:devatlas@localhost:5432/devatlas_test?schema=public
CORS_ORIGIN=http://localhost:3000
CONTENT_DIR=./packages/content/src/__tests__/fixtures

# Web
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001

# AI automation (optional)
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
LOCAL_LLM_BASE_URL=http://127.0.0.1:11435/v1
LOCAL_LLM_MODEL=qwen3-4b-thinking
LOCAL_LLM_SERVER=/home/dev/Downloads/tools/llama.cpp/build/bin/llama-server
LOCAL_LLM_CHAT_MODEL=/home/dev/Downloads/tools/Qwen3-4B-Thinking-2507-Q3_K_L.gguf
LOCAL_LLM_EMBED_MODEL=/home/dev/Downloads/tools/bge-m3.gguf
LOCAL_LLM_HOST=127.0.0.1
LOCAL_LLM_PORT=11435
LOCAL_EMBEDDING_BASE_URL=http://127.0.0.1:11436/v1
LOCAL_EMBEDDING_MODEL=bge-m3
LOCAL_EMBEDDING_PORT=11436
LOCAL_LLM_N_GPU_LAYERS=99
LOCAL_LLM_CTX=16384
LOCAL_LLM_THREADS=8
