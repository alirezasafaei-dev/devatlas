{
  "name": "devatlas-platform",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "build": "turbo run build",
    "build:api": "pnpm --filter @devatlas/api build",
    "build:web": "pnpm --filter @devatlas/web build",
    "dev": "turbo run dev",
    "dev:api": "pnpm --filter @devatlas/api dev",
    "dev:web": "pnpm --filter @devatlas/web dev",
    "lint": "turbo run lint",
    "lint:api": "pnpm --filter @devatlas/api lint",
    "lint:web": "pnpm --filter @devatlas/web lint",
    "lint:report": "eslint . -f github",
    "test": "turbo run test",
    "test:api": "pnpm --filter @devatlas/api test",
    "test:web": "pnpm --filter @devatlas/web test",
    "typecheck": "turbo run typecheck",
    "typecheck:api": "pnpm --filter @devatlas/api typecheck",
    "typecheck:web": "pnpm --filter @devatlas/web typecheck",
    "verify:api": "pnpm --filter @devatlas/api db:check && pnpm lint:api && pnpm typecheck:api && pnpm test:api",
    "verify:web": "pnpm lint:web && pnpm typecheck:web && pnpm test:web",
    "agent:verify": "node scripts/agent-verify.mjs",
    "agent:context": "node scripts/agent-context.mjs",
    "agent:github": "node scripts/github-hub.mjs",
    "agent:deepseek": "python3 scripts/deepseek-review.py",
    "agent:deepseek:local": "python3 scripts/deepseek-review.py --provider local",
    "agent:inventory": "python3 scripts/github-inventory.py",
    "agent:autopilot": "node scripts/agent-autopilot.mjs",
    "agent:ops": "node scripts/agent-ops.mjs",
    "agent:smart": "node scripts/agent-smart.mjs",
    "agent:auto": "node scripts/agent-smart.mjs",
    "agent:auto:offline": "node scripts/agent-smart.mjs --offline",
    "agent:auto:lean": "AGENT_LOW_TOKEN_MODE=1 pnpm agent:auto --offline --no-api --json && (pnpm agent:devflow review --diff staged --timeout-seconds 60 --json || true)",
    "gapcode:index": "node scripts/gapcode-index.mjs",
    "gapcode:index:metrics": "node scripts/gapcode-index-metrics.mjs",
    "gapcode:bootstrap": "node scripts/gapcode-bootstrap.mjs",
    "gapcode:context": "node scripts/gapcode-context.mjs",
    "gapcode:scopes": "node scripts/gapcode-scopes.mjs",
    "gapcode:metrics": "node scripts/gapcode-metrics.mjs",
    "gapcode:verify": "node scripts/gapcode-verify.mjs",
    "agent:tools": "node scripts/agent-tools-audit.mjs",
    "doctor": "node scripts/doctor.mjs",
    "health": "node scripts/health.mjs",
    "health:verbose": "node scripts/health.mjs --verbose",
    "ops:alerts": "node scripts/ops-alert.mjs",
    "generate:api-client": "pnpm --filter @devatlas/api-client generate",
    "ingest:smoke": "node scripts/search-smoke.mjs --ingest-pipeline --require-positive",
    "search:smoke": "node scripts/search-smoke.mjs",
    "deploy:staging": "node scripts/deploy/staging-release.mjs",
    "staging:data": "node scripts/staging-data-rehearsal.mjs",
    "staging:readiness": "node scripts/staging-readiness.mjs",
    "agent:vps": "node scripts/vps-audit.mjs",
    "agent:preflight": "node scripts/agent-preflight.mjs",
    "agent:local:chat": "node scripts/local-llm.mjs chat",
    "agent:local:embed": "node scripts/local-llm.mjs embed",
    "agent:local:smoke": "node scripts/local-llm.mjs smoke",
    "agent:local:smoke:embed": "node scripts/local-llm.mjs smoke --mode=embed",
    "agent:devflow": "node scripts/agent-devflow.mjs",
    "agent:devflow:install-hooks": "node scripts/agent-devflow.mjs install-hooks",
    "agent:offline:install": "bash scripts/install-offline-ai-services.sh",
    "agent:offline:review:last": "cat tmp/agent-devflow/review-latest.json"
  },
  "devDependencies": {
    "@commitlint/cli": "20.5.3",
    "@commitlint/config-conventional": "20.5.3",
    "@eslint/js": "10.0.1",
    "@openapitools/openapi-generator-cli": "2.32.0",
    "@typescript-eslint/eslint-plugin": "8.59.1",
    "@typescript-eslint/parser": "8.59.1",
    "esbuild": "0.28.0",
    "eslint": "10.3.0",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-boundaries": "6.0.2",
    "eslint-plugin-import": "2.32.0",
    "fast-glob": "3.3.3",
    "globals": "17.6.0",
    "ignore": "7.0.5",
    "lint-staged": "16.4.0",
    "ts-error-formatter": "0.2.1",
    "ts-node": "10.9.2",
    "tsup": "8.5.1",
    "turbo": "2.9.8",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.1",
    "vite": "8.0.10",
    "vitest": "4.1.5",
    "whatwg-encoding": "3.1.1"
  },
  "packageManager": "pnpm@10.33.2",
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=20.11.0 <23",
    "pnpm": ">=8"
  }
}
